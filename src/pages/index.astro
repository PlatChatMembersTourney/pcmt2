---
// import global styles
import "../styles/global.css"

import matchResultsSeason3 from '../data/s3/na/matches/matches.json';

// TypeScript format of matches.json
// this is just to help us with writing the code
// (lets us reference the schema quickly)

// as another benefit, the linter will get angry when you use the schema incorrectly

interface Match {
	id: string;
	team1: string;
	team2: string;
	team1Name: string;
	team2Name: string;
	score1: number;

	// blah blah blah...
	// TODO finish this type

	combinedStats: Stats[]
}

interface Stats {
	team: string;
	teamName: string;
	players: Player[];
}

interface Player {
	Player: string;
	'R1.0': number;
	ACS: number;
	K: number;
	D: number;
	A: number;
	// blah blah blah
}

const results = matchResultsSeason3 as Match[]

const mrCrocManKills = results.reduce((acc, match) => {
	const stats = match.combinedStats.find(s => s.players.some(p => p.Player === 'MrCrocMan'));
	if (stats) {
		const player = stats.players.find(p => p.Player === 'MrCrocMan');
		if (player) {
			return acc + player.K;
		}
	}
	return acc;
}, 0);

let darkTheme = false;

let toggleDarkTheme = () => {
	darkTheme = !darkTheme;
}

import Header from '../components/Header.astro';
---

<html lang="en">
<head>
    <meta charset="utf-8"/>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
    <link rel="icon" href="/favicon.ico"/>
    <meta name="viewport" content="width=device-width"/>
    <meta name="generator" content={Astro.generator}/>
    <title>pcmt 2.0</title>
</head>
<body class="bg-white text-black dark:bg-[#3a3a3a] dark:text-white font-sans m-0">
<Header />
<main class="mx-auto max-w-[1200px] px-[30px]">
  <section class="relative my-5 flex min-h-[400px] items-center overflow-hidden rounded-[15px] bg-linear-to-r from-[#f0f0f0] to-[#e8e8e8] dark:from-[#272727] dark:to-[#282828]">
    <div class="relative z-10 ml-[100px] w-[600px] max-w-[80%] p-[25px] text-gray-800 dark:text-[whitesmoke]">
      <h1 class="text-3xl font-bold text-[#2a8a8c] dark:text-[#6dc5c7]">What is the PCMT?</h1>
      <p class="mt-4">
        The Plat Chat Members Tournament (PCMT) is a community-run Valorant
        tournament organized by and for members of the Plat Chat community.
        <br /><br />
        Whether you're here for your first taste of structured Valorant or just
        here for a good time, PCMT provides a competitive yet fun environment to
        test your skills and connect with other members.
      </p>
    </div>
    <img
      src="/icons/PCMT Logo.png"
      alt=""
      class="absolute top-1/2 right-[75px] w-[500px] -translate-y-1/2 opacity-30"
    />
  </section>
</main>
</body>
</html>

<!-- dark theme, shamelessly stolen from astro docs -->
<script is:inline>
	const theme = (() => {
		const localStorageTheme = localStorage?.getItem("theme") ?? '';
		if (['dark', 'light'].includes(localStorageTheme)) {
			return localStorageTheme;
		}
		if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
			return 'dark';
		}
		return 'light';
	})();

	if (theme === 'light') {
		document.body.classList.remove('dark');
	} else {
		document.body.classList.add('dark');
	}

	window.localStorage.setItem('theme', theme);

	const updateNightLabel = () => {
		const state = document.getElementById("nightState");
		if (!state) return;
		const isDark = document.body.classList.contains("dark");
		state.textContent = isDark ? "on" : "off";
		state.classList.toggle("text-green-500", isDark);
		state.classList.toggle("text-red-500", !isDark);
	}

	const handleToggleClick = () => {
		const element = document.body;
		element.classList.toggle("dark");

		const isDark = element.classList.contains("dark");
		localStorage.setItem("theme", isDark ? "dark" : "light");
		updateNightLabel();
	}

	document.getElementById("themeToggle")?.addEventListener("click", handleToggleClick);
	updateNightLabel();
</script>
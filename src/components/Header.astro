---
interface Props {
    activePage: string;
}

const { activePage } = Astro.props;

const links = [
    { label: "Home", href: "/" },
    { label: "Matches", href: "/matches" },
    { label: "Standings", href: "/standings" },
    { label: "Stats", href: "/stats" }
];
---

<header class="dark:bg-[#1e1e1e] bg-gray-300 text-white h-16 text-[larger] sticky top-0 z-50 w-full">
    <div class="mx-auto flex max-w-[1260px] h-full items-stretch justify-between">
        <!-- left group: logo + title + nav links -->
        <div class="hidden md:flex items-stretch">
            <a href="/" class="flex items-center gap-6 border-l border-neutral-200 dark:border-[#333] pl-4 pr-4">
                <img src="/icons/PCMT Logo.png" alt="PCMT Logo" class="h-12 w-auto hidden dark:block" />
                <img src="/icons/PCMT Logo Light.png" alt="PCMT Logo" class="h-12 w-auto block dark:hidden" />
                <span class="lg:block hidden text-black dark:text-white">Plat Chat Members Tournament</span>
                <span class="block lg:hidden text-black dark:text-white">PCMT</span>
            </a>

            <nav class="flex items-stretch border-r border-neutral-200 dark:border-[#333]">
                {links.map((link) => (
                    <a
                        href={link.href}
                        class={
                            ((link.label === activePage) ? "text-neutral-500 dark:text-white " : "") +
                            "flex items-center border-l border-neutral-200 dark:border-[#333] px-6 text-[15px] dark:text-[#aaa] text-neutral-800 transition-colors dark:hover:text-white hover:text-neutral-500"
                        }
                    >
                        {link.label}
                    </a>
                ))}
            </nav>
        </div>

        <div class="flex flex-col md:hidden">
            <button onclick="toggleNav()" class="inline-flex items-center justify-center p-2 ml-2 my-auto rounded-md text-neutral-400 hover:text-white dark:hover:bg-neutral-700 hover:bg-neutral-400 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-white" aria-expanded="false">
                <svg id="nav-menu-closed" class="h-6 w-6 block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
                <svg id="nav-menu-open" class="h-6 w-6 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>

            <div id="mobile-menu" class="hidden md:hidden">
                <div class="space-y-1 absolute w-full bg-neutral-300 dark:bg-neutral-800 z-40 flex flex-col">
                    {links.map((link) => (
                        <a
                            href={link.href}
                            class={
                                ((link.label === activePage) ? "text-neutral-500 dark:text-white " : "") +
                                "flex items-center py-3 px-6 text-[15px] border-b mb-0 border-neutral-200 dark:border-[#333] dark:text-[#aaa] text-neutral-800 transition-colors dark:hover:text-white hover:text-neutral-500"
                            }
                        >
                            {link.label}
                        </a>
                    ))}
                </div>
            </div>
        </div>

        <div class="flex md:hidden w-full ml-2">
            <a href="/" class="flex items-center gap-4 dark:border-[#333]">
                <img src="/icons/PCMT Logo.png" alt="PCMT Logo" class="h-12 w-auto hidden dark:block" />
                <img src="/icons/PCMT Logo Light.png" alt="PCMT Logo" class="h-12 w-auto block dark:hidden" />
                <span class="md:block hidden text-black dark:text-white">Plat Chat Members Tournament</span>
                <span class="block md:hidden text-black dark:text-white">PCMT</span>
            </a>
        </div>

        <!-- right group: night-mode toggle -->
        <div class="flex items-stretch">
            <button
                id="themeToggle"
                type="button"
                class="flex items-center gap-2 border-l border-r border-neutral-200 dark:border-[#333] px-4 text-[11px] text-neutral-800 dark:text-[#aaa] transition-colors hover:text-neutral-500 dark:hover:text-white cursor-pointer"
            >
                <span class="text-base leading-none">⏾</span>
                <span class="flex flex-col items-start leading-tight">
                    <span>Night:</span>
                    <span id="nightState" class="font-semibold text-red-500">off</span>
                </span>
            </button>
        </div>
    </div>
</header>
<script is:inline>
    let mobileNavExpanded = false;

    function toggleNav() {
        let classes = document.getElementById('mobile-menu')?.classList;
        let closeIcon = document.getElementById('nav-menu-closed')?.classList;
        let openIcon = document.getElementById('nav-menu-open')?.classList;

        if (!classes || !closeIcon || !openIcon) {
            return;
        }

        if (!mobileNavExpanded) {
            classes.remove('hidden');
            classes.remove('sm:hidden');
            classes.add('block');
            classes.add('sm:block');

            openIcon.remove('hidden');
            openIcon.add('block');

            closeIcon.remove('block');
            closeIcon.add('hidden');
        } else {
            classes.add('hidden');
            classes.add('sm:hidden');
            classes.remove('block');
            classes.remove('sm:block');

            openIcon.remove('block');
            openIcon.add('hidden');

            closeIcon.remove('hidden');
            closeIcon.add('block');
        }
        mobileNavExpanded = !mobileNavExpanded;
    }

    // dark theme, shamelessly stolen from astro docs
    const theme = (() => {
        const localStorageTheme = localStorage?.getItem("theme") ?? '';
        if (['dark', 'light'].includes(localStorageTheme)) {
            return localStorageTheme;
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            return 'dark';
        }
        return 'light';
    })();

    if (theme === 'light') {
        document.body.classList.remove('dark');
    } else {
        document.body.classList.add('dark');
    }

    window.localStorage.setItem('theme', theme);

    const updateNightLabel = () => {
        const state = document.getElementById("nightState");
        if (!state) return;
        const isDark = document.body.classList.contains("dark");
        state.textContent = isDark ? "on" : "off";
        state.classList.toggle("text-green-500", isDark);
        state.classList.toggle("text-red-500", !isDark);
    }

    const handleToggleClick = () => {
        const element = document.body;
        element.classList.toggle("dark");

        const isDark = element.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");

        if(isDark) {
            let smoke = new Audio('/res/smoke.mp3');
            smoke.play();
        } else {
            let flashbang = new Audio('/res/flashbang.mp3');
            flashbang.play();
        }

        updateNightLabel();
    }

    document.getElementById("themeToggle")?.addEventListener("click", handleToggleClick);
    updateNightLabel();
</script>

